{
  "name": "juice",
  "version": "1.2.0",
  "description": "macOS menu bar timer app",
  "main": "out/main/index.js",
  "author": "kanayama",
  "homepage": ".",
  "scripts": {
    "ensure-electron": "node scripts/ensure-electron.mjs",
    "predev": "node scripts/ensure-electron.mjs",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "prepreview": "node scripts/ensure-electron.mjs",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "package": "electron-vite build && electron-builder --config electron-builder.yml",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p lambda/tsconfig.json",
    "knip": "knip",
    "lint": "eslint . --ext .ts,.tsx",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "electron-log": "^5.4.4",
    "iconoir-react": "^7.11.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^20.11.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "dependency-cruiser": "^17.4.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^8.56.0",
    "jsdom": "^28.1.0",
    "knip": "^6.14.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "vite": "^7.3.5",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.kanaami.juice",
    "productName": "Juice",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "directories": {
      "output": "dist"
    }
  }
}
